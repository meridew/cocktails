# apps/web build-time env (Vite). Copy to apps/web/.env.local to override.
# The web/PWA build needs NONE of these — it talks to /api same-origin.

# Native (Capacitor) build only: absolute API base, INCLUDING the /api suffix.
# VITE_API_BASE=https://cock.meridew.com/api

# Native (Capacitor) build only: drop the service worker (the app is its own shell).
# VITE_TARGET=native
