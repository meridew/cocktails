# API configuration (copy to .env for local dev; set as real env on the NAS)
PORT=8787
# Lock this to the site origin in production, e.g. https://cock.meridew.com
ALLOWED_ORIGIN=*
# Bartender shared secret (replaced by a proper staff login in Phase 3)
BARTENDER_KEY=1337
# SQLite file (a Docker volume on the NAS)
DB_PATH=./data/cocktails.sqlite
