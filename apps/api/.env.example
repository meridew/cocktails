# API configuration (copy to .env for local dev; set as real env on the NAS)
PORT=8787
# CORS allow-list (comma-separated). Prod defaults to the app WebView origins;
# the website is same-origin via Caddy so needs no entry. '*' for local only.
ALLOWED_ORIGIN=*
# Bartender shared secret (replaced by a proper staff login in Phase 3)
BARTENDER_KEY=1337
# SQLite file (a Docker volume on the NAS)
DB_PATH=./data/cocktails.sqlite
# Web Push (VAPID). Generate with: npm -w @cocktails/api run gen-vapid
# Empty → push disabled. Browsers allow push only in a secure context
# (https or http://localhost), so localhost dev works.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:bar@meridew.com
