# Copy to infra/runner/.env on the NAS (do NOT commit the real token).
# A SHORT-LIVED runner registration token (not an account PAT). Regenerate:
#   gh api -X POST repos/meridew/cocktails/actions/runners/registration-token --jq .token
# After a NAS reboot, refresh this and `docker-compose up -d` again.
RUNNER_TOKEN=replace_with_registration_token
