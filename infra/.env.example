# Copy to infra/.env on the NAS. docker compose reads this.

# Images published by CI (owner lowercased by GHCR).
API_IMAGE=ghcr.io/meridew/cocktails-api:latest
WEB_IMAGE=ghcr.io/meridew/cocktails-web:latest

# CORS allow-list (comma-separated) and the host port Caddy listens on.
# The website is same-origin via Caddy so it needs no entry; list the native
# app WebView origins once the apps exist. Point the router port-forward at
# PUBLIC_PORT. Avoids DSM's 80/443.
ALLOWED_ORIGIN=capacitor://localhost,https://localhost
PUBLIC_PORT=8088

# Staff login — seeds the first account on a fresh DB. The password is a secret
# (also store it as the GitHub secret STAFF_PASSWORD for CI deploys).
STAFF_EMAIL=bar@meridew.com
STAFF_PASSWORD=change-me-to-a-strong-passphrase

# Web Push (VAPID) — generate once with `npm -w @cocktails/api run gen-vapid`.
# VAPID_PRIVATE_KEY is a SECRET (also add it as a GitHub secret); the public
# key is safe to expose. Empty → push disabled. Push needs HTTPS to work in a
# browser, so it stays inert until the public-HTTPS cutover.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:bar@meridew.com
