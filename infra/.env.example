# Copy to infra/.env on the NAS. docker compose reads this.

# Images published by CI (owner lowercased by GHCR).
API_IMAGE=ghcr.io/meridew/cocktails-api:latest
WEB_IMAGE=ghcr.io/meridew/cocktails-web:latest

# CORS allow-list (comma-separated) and the host port Caddy listens on.
# The website is same-origin via Caddy so it needs no entry; list the native
# app WebView origins once the apps exist. Point the router port-forward at
# PUBLIC_PORT. Avoids DSM's 80/443.
ALLOWED_ORIGIN=capacitor://localhost,https://localhost
PUBLIC_PORT=8088

# Bartender shared secret (Phase 3 replaces this with a real staff login).
BARTENDER_KEY=change-me-to-a-strong-passphrase
